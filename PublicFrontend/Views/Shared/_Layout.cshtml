<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — UTN GolMundial 2026</title>
    <link rel="stylesheet" href="~/css/public.css" />
</head>
<body>
    <nav class="navbar">
        <a class="navbar-brand" href="/">⚽ UTN <span>GolMundial</span> 2026</a>
        <div class="navbar-nav">
            <a class="nav-link" asp-controller="Home" asp-action="Index">🏠 Inicio</a>
            <a class="nav-link" asp-controller="Calendario" asp-action="Index">📅 Calendario</a>
            <a class="nav-link" asp-controller="Posiciones" asp-action="Index">🏆 Posiciones</a>
            <a class="nav-link" asp-controller="Predicciones" asp-action="Index">🎯 Predicciones</a>
            <a class="nav-link" asp-controller="Ranking" asp-action="Index">👑 Ranking</a>
        </div>
    </nav>

    @RenderBody()

    <footer class="footer">
        <p>⚽ UTN <span>GolMundial</span> 2026 — Universidad Técnica del Norte — Ibarra, Ecuador</p>
        <p style="margin-top:8px">UTNGolCoin es una moneda académica ficticia sin valor monetario real.</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>