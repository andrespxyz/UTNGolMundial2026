@{
    ViewData["Title"] = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="text-align:center; padding:80px 24px;">
    <div style="font-size:80px; margin-bottom:24px;">⚠️</div>
    <h2 style="color:#CC0000; font-size:32px; margin-bottom:16px;">
        Algo salió mal
