@model PublicFrontend.Models.Partido
@{
    ViewData["Title"] = "Detalle del partido";
}

<div class="container">
    <a href="@Url.Action("Index", "Calendario")" style="display:inline-block; margin-bottom:16px; color:#CC0000; text-decoration:none; font-weight:600;">&larr; Volver al calendario</a>

    <h2 class="section-title">
        @(Model.Grupo == "" ? "Fase Eliminatoria" : $"Grupo {Model.Grupo}") — @Model.Fase
    </h2>

    <div class="partido-card" style="flex-direction:column; align-items:center; padding:32px;">
        <div style="display:flex; align-items:center; justify-content:center; width:100%; gap:32px;">
            <div class="equipo">
                <div class="equipo-nombre" style="font-size:22px">@(Model.SeleccionLocal?.Nombre ?? "TBD")</div>
                <div class="equipo-codigo">@(Model.SeleccionLocal?.Codigo ?? "")</div>
            </div>
            <div style="text-align:center;">
                @if (Model.Estado == "finalizado")
                {
                    <div class="marcador" style="font-size:36px">@Model.GolesLocal - @Model.GolesVisitante</div>
                    <span class="badge badge-green">Finalizado</span>
                }
                else
                {
                    <div class="marcador" style="font-size:28px; color:#666">VS</div>
                    <span class="badge badge-gray">@(Model.Estado == "en_juego" ? "En juego" : "Programado")</span>
                }
            </div>
            <div class="equipo">
                <div class="equipo-nombre" style="font-size:22px">@(Model.SeleccionVisitante?.Nombre ?? "TBD")</div>
                <div class="equipo-codigo">@(Model.SeleccionVisitante?.Codigo ?? "")</div>
            </div>
        </div>

        <div style="margin-top:24px; text-align:center; color:#444; line-height:1.8;">
            <div>🗓️ @Model.FechaHoraEcuador</div>
            <div>📍 @(Model.Sede?.Nombre ?? "Sede por definir") — @(Model.Sede?.Ciudad ?? "")@(string.IsNullOrEmpty(Model.Sede?.Pais) ? "" : $", {Model.Sede.Pais}")</div>
        </div>
    </div>
</div>
