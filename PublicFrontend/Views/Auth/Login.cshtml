@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="max-width:480px; margin:60px auto;">
    <div class="card" style="padding:40px;">
        <div style="text-align:center; margin-bottom:32px;">
            <div style="font-size:48px;">⚽</div>
            <h2 style="color:#CC0000; margin:8px 0;">Iniciar Sesión</h2>
            <p style="color:#666; font-size:14px;">UTN GolMundial 2026</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-error">❌ @ViewBag.Error</div>
        }

        <form method="post" asp-action="Login">
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" class="form-control" placeholder="tu@email.com" required />
            </div>
            <div class="form-group">
                <label>Contraseña</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required />
            </div>
            <button type="submit" class="btn btn-red" style="width:100%; margin-top:8px;">
                Iniciar Sesión
            </button>
        </form>

        <div style="text-align:center; margin-top:24px; color:#666; font-size:14px;">
            ¿No tienes cuenta?
            <a asp-controller="Auth" asp-action="Registro" style="color:#CC0000; font-weight:700;">Regístrate aquí</a>
        </div>
    </div>
</div>