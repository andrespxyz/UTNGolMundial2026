@model PublicFrontend.Models.ViewModels.RegistroViewModel
@{
    ViewData["Title"] = "Registro";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="max-width:480px; margin:60px auto;">
    <div class="card" style="padding:40px;">
        <div style="text-align:center; margin-bottom:32px;">
            <div style="font-size:48px;">🏆</div>
            <h2 style="color:#CC0000; margin:8px 0;">Crear Cuenta</h2>
            <p style="color:#666; font-size:14px;">Recibe 10 UTNGolCoin de bienvenida</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-error">❌ @ViewBag.Error</div>
        }

        <form method="post" asp-action="Registro">
            <div class="form-group">
                <label>Nombre de usuario</label>
                <input asp-for="NombreUsuario" class="form-control" placeholder="ej. andres123" />
                <span asp-validation-for="NombreUsuario" style="color:#CC0000; font-size:13px;"></span>
            </div>
            <div class="form-group">
                <label>Email</label>
                <input asp-for="Email" class="form-control" placeholder="tu@email.com" />
                <span asp-validation-for="Email" style="color:#CC0000; font-size:13px;"></span>
            </div>
            <div class="form-group">
                <label>Contraseña</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Mínimo 6 caracteres" />
                <span asp-validation-for="Password" style="color:#CC0000; font-size:13px;"></span>
            </div>
            <button type="submit" class="btn btn-red" style="width:100%; margin-top:8px;">
                Crear cuenta
            </button>
        </form>

        <div style="text-align:center; margin-top:24px; color:#666; font-size:14px;">
            ¿Ya tienes cuenta?
            <a asp-controller="Auth" asp-action="Login" style="color:#CC0000; font-weight:700;">Inicia sesión</a>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}