@model List<PublicFrontend.Models.Billetera>
@{
    ViewData["Title"] = "Ranking";
    int pos = 1;
}

<div class="container">
    <h2 class="section-title">👑 Ranking UTNGolCoin</h2>

    @if (Model.Any())
    {
        @foreach (var b in Model)
        {
            string posClass = pos == 1 ? "gold" : pos == 2 ? "silver" : pos == 3 ? "bronze" : "";
            string medal = pos == 1 ? "🥇" : pos == 2 ? "🥈" : pos == 3 ? "🥉" : pos.ToString();
            <div class="ranking-item">
                <div class="ranking-pos @posClass">@medal</div>
                <div class="ranking-nombre">@b.NombreUsuario</div>
                <div class="ranking-saldo">@b.Saldo <small style="font-size:12px; color:#aaa">UTNGolCoin</small></div>
            </div>
            pos++;
        }
    }
    else
    {
        <div class="card" style="text-align:center; color:#666; padding:60px">
            <p style="font-size:48px">👑</p>
            <p>No hay usuarios registrados aún.</p>
        </div>
    }
</div>