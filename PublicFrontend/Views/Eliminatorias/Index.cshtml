@model Dictionary<string, List<PublicFrontend.Models.Partido>>
@{
    ViewData["Title"] = "Eliminatorias";
    var ordenFases = new[] { "Dieciseisavos", "Octavos", "Cuartos", "Semifinal", "TercerPuesto", "Final" };
    var nombresFase = new Dictionary<string, string>
    {
        { "Dieciseisavos", "🎯 Dieciseisavos de Final" },
        { "Octavos", "🎯 Octavos de Final" },
        { "Cuartos", "🎯 Cuartos de Final" },
        { "Semifinal", "🎯 Semifinal" },
        { "TercerPuesto", "🥉 Tercer Puesto" },
        { "Final", "🏆 Final" }
    };
}

<div class="container">
    <h2 class="section-title">🏆 Cuadro de Eliminatorias — Mundial 2026</h2>
    <p style="color:#aaa; margin-bottom:32px;">Sigue el avance de los 32 clasificados desde Dieciseisavos hasta la Final.</p>

    @foreach (var fase in ordenFases)
    {
        var partidos = Model.ContainsKey(fase) ? Model[fase] : new List<PublicFrontend.Models.Partido>();
        <div style="margin-bottom:40px;">
            <h3 style="color:#fff; border-left:4px solid #CC0000; padding-left:12px; margin-bottom:16px;">
                @nombresFase[fase]
                <span style="color:#666; font-size:14px; font-weight:normal;">
                    (@partidos.Count @(partidos.Count == 1 ? "partido" : "partidos"))
                </span>
            </h3>

            @if (!partidos.Any())
            {
                <div class="card" style="text-align:center; color:#666; padding:24px;">
                    Aún no definido — depende de los resultados de la ronda anterior.
                </div>
            }
            else
            {
                <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:16px;">
                    @foreach (var p in partidos)
                    {
                        bool finalizado = p.Estado == "finalizado";
                        bool localGana = finalizado && p.GolesLocal > p.GolesVisitante;
                        bool visitanteGana = finalizado && p.GolesVisitante > p.GolesLocal;

                        <div class="partido-card" style="flex-direction:column; align-items:stretch; padding:16px;">
                            <div style="display:flex; align-items:center; justify-content:space-between;">
                                <div class="equipo" style="@(localGana ? "font-weight:700; color:#fff;" : "color:#888;")">
                                    @(p.SeleccionLocal?.Nombre ?? "Por definir")
                                </div>
                                <div class="marcador" style="font-size:20px; color:#CC0000; font-weight:700; min-width:60px; text-align:center;">
                                    @if (finalizado)
                                    {
                                        @($"{p.GolesLocal} - {p.GolesVisitante}")
                                    }
                                    else
                                    {
                                        <span style="font-size:14px; color:#666;">VS</span>
                                    }
                                </div>
                                <div class="equipo" style="text-align:right; @(visitanteGana ? "font-weight:700; color:#fff;" : "color:#888;")">
                                    @(p.SeleccionVisitante?.Nombre ?? "Por definir")
                                </div>
                            </div>
                            <div class="partido-info" style="margin-top:12px; font-size:12px;">
                                📅 @p.FechaHoraEcuador
                                @if (p.Sede != null)
                                {
                                    <text> — 📍 @p.Sede.Ciudad</text>
                                }
                            </div>
                            <div style="margin-top:8px;">
                                @if (finalizado)
                                {
                                    <span class="badge badge-green">Finalizado</span>
                                }
                                else
                                {
                                    <span class="badge badge-gray">Programado</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>